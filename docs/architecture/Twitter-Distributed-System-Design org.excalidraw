    {
      "id": "Vp4wsO4gNesOU9EMxdgZ2",
      "type": "text",
      "x": -3113.993895174001,
      "y": 2016.9330197663385,
      "width": 1058.5989990234375,
      "height": 225,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b2p",
      "roundness": null,
      "seed": 427856248,
      "version": 720,
      "versionNonce": 1025203064,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1781452112709,
      "link": null,
      "locked": false,
      "text": "this service responsible for authentication.\nSupported authentication is JWT\n\nendpoints\n    /sign-up                -   create new user (user-id) is unique\n    /login                   -   username and password -> generate access token and refresh token\n    /delete-user           -   before deactivate account. user need to login\n    /change-password    -   user should send old password and new password (old password for verification)\n    /reset-password      -   need to send some verification details like(dob, username, name)",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "this service responsible for authentication.\nSupported authentication is JWT\n\nendpoints\n    /sign-up                -   create new user (user-id) is unique\n    /login                   -   username and password -> generate access token and refresh token\n    /delete-user           -   before deactivate account. user need to login\n    /change-password    -   user should send old password and new password (old password for verification)\n    /reset-password      -   need to send some verification details like(dob, username, name)",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "OZs-qIUpzwvKPxzVquj-b",
